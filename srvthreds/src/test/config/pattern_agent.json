    "eventSchemaPath": "src/ts/thredlib/schemas/event.json",
    "systemSpecSchemaPath": "src/ts/thredlib/schemas/systemSpec.json",
    "systemSpecPath": "samples/sample.system.json",
    "apiKey": "${AI_PROVIDER_API_KEY}"
  }
}
